# SparkyFitness on Fly.io — secret values reference (do NOT commit a filled-in copy).
# These are pushed with `fly secrets set` (see README), not loaded as a file.
#
# Generate the two cryptographic values:
#   API key (64-char hex):   openssl rand -hex 32
#   Better Auth secret:      openssl rand -hex 32   (or any long random string)
#
# IMPORTANT: BETTER_AUTH_SECRET must stay constant forever. Changing it after
# users enable 2FA locks them out.

# --- db app (set on sparkyfitness-db) ---
POSTGRES_DB=sparkyfitness_db
POSTGRES_USER=sparky
POSTGRES_PASSWORD=changeme_db_password

# --- server app (set on sparkyfitness-server) ---
# Must match the db app's POSTGRES_PASSWORD:
SPARKY_FITNESS_DB_PASSWORD=changeme_db_password
# App-level DB user password (server creates this user on first run):
SPARKY_FITNESS_APP_DB_PASSWORD=changeme_app_password
# 64-char hex, from `openssl rand -hex 32`:
SPARKY_FITNESS_API_ENCRYPTION_KEY=changeme_64_hex
# Strong + PERMANENT:
BETTER_AUTH_SECRET=changeme_strong_persistent_secret
